{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "image": {
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "tag": { "type": "string" }
            }
        },
        "registry": {
            "type": "object",
            "properties": {
                "domain": { "type": "string" }
            }
        },
        "controller": {
            "type": "object",
            "properties": {
                "maxPokes": { "type": "integer", "minimum": 1 },
                "backoff": { "type": "string" },
                "namespacePrefix": { "type": "string" },
                "watchLabelSelector": { "type": "string" }
            }
        },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "metrics": {
            "type": "object",
            "properties": {
                "port": { "type": "integer" }
            }
        }
    }
}
